#!/usr/bin/env bash
# neewe — NEEWE Framework CLI (Sprint 1 minimum: phase-state primitive)
#
# Subcommands:
#   neewe init                          Create .neewe/state.json with defaults
#   neewe show                          Pretty-print current state
#   neewe set-phase <phase>             Atomically update phase + phase_started_at
#   neewe get <field>                   Read a field (dot-path: model_routing.main)
#   neewe help                          Print this help
#
# Phases: 00-intake | 01-spec | 02-plan | 03-execute | 04-validate | 05-goal-mode
#
# State file: .neewe/state.json  (lockfile: .neewe/.state.lock — atomic mkdir-based)
#
# Polyglot: invoked from neewe.cmd on Windows (Git Bash); direct on Unix.

set -euo pipefail

NEEWE_VERSION="0.1.0"
STATE_DIR=".neewe"
STATE_FILE="${STATE_DIR}/state.json"
LOCK_DIR="${STATE_DIR}/.state.lock"

# ────────────────────────────────────────────────────────────────────────────
# JSON helpers (prefer jq; fall back to python3)
# ────────────────────────────────────────────────────────────────────────────

_have_jq() { command -v jq >/dev/null 2>&1; }
_have_python() { command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; }

_py() {
  if command -v python3 >/dev/null 2>&1; then python3 "$@"; else python "$@"; fi
}

json_get() {
  # json_get <file> <dot.path>
  local file="$1" path="$2"
  if _have_jq; then
    jq -r ".${path} // empty" "$file"
  elif _have_python; then
    _py -c "import json,sys; d=json.load(open('${file}'));
parts='${path}'.split('.')
for p in parts: d=d.get(p, '') if isinstance(d, dict) else ''
print(d if d is not None else '')"
  else
    echo "ERROR: need jq or python to parse JSON" >&2
    return 1
  fi
}

json_set_phase() {
  # json_set_phase <file> <new_phase>
  local file="$1" phase="$2"
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  if _have_jq; then
    jq --arg p "$phase" --arg t "$now" '.phase = $p | .phase_started_at = $t' "$file" > "${file}.tmp"
    mv "${file}.tmp" "$file"
  elif _have_python; then
    _py -c "
import json
with open('${file}') as f: d = json.load(f)
d['phase'] = '${phase}'
d['phase_started_at'] = '${now}'
with open('${file}.tmp', 'w') as f: json.dump(d, f, indent=2)
" && mv "${file}.tmp" "$file"
  else
    echo "ERROR: need jq or python to mutate JSON" >&2
    return 1
  fi
}

json_mutate() {
  # json_mutate <file> <jq-expression>
  # Apply an arbitrary jq mutation (or python equivalent) to the file atomically.
  local file="$1" jq_expr="$2" py_code="$3"
  if _have_jq; then
    jq "$jq_expr" "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
  elif _have_python; then
    _py -c "$py_code" && mv "${file}.tmp" "$file"
  else
    echo "ERROR: need jq or python to mutate JSON" >&2
    return 1
  fi
}

# ────────────────────────────────────────────────────────────────────────────
# Lock helpers (atomic mkdir-based — POSIX-portable + works on Git Bash)
# ────────────────────────────────────────────────────────────────────────────

acquire_lock() {
  # Stale threshold = 5s. JSON writes complete in <100ms; anything held longer
  # is a poison pill from a crashed prior invocation.
  # On stale detection we clear and retry mkdir immediately (no sleep).
  local max_attempts=20
  local stale_threshold_sec=5
  local attempt=0
  while [ $attempt -lt $max_attempts ]; do
    if mkdir "$LOCK_DIR" 2>/dev/null; then
      trap 'rmdir "'"$LOCK_DIR"'" 2>/dev/null || true' EXIT
      return 0
    fi
    # Lock exists. Check if it's stale (poison pill from crashed prior run).
    if [ -d "$LOCK_DIR" ]; then
      local lock_mtime age
      lock_mtime=$(stat -c %Y "$LOCK_DIR" 2>/dev/null || stat -f %m "$LOCK_DIR" 2>/dev/null || echo 0)
      age=$(( $(date +%s) - lock_mtime ))
      if [ "$age" -gt "$stale_threshold_sec" ]; then
        echo "[neewe] clearing stale lock (age=${age}s > ${stale_threshold_sec}s threshold) at $LOCK_DIR" >&2
        rmdir "$LOCK_DIR" 2>/dev/null || true
        continue   # retry mkdir immediately, no sleep
      fi
    fi
    # Lock is fresh — another invocation is mid-write. Jittered wait (50-200 ms).
    sleep "0.$(printf '%03d' $((50 + RANDOM % 150)))"
    attempt=$((attempt + 1))
  done
  echo "[neewe] ERROR: could not acquire lock after ${max_attempts} attempts (lock at $LOCK_DIR)" >&2
  return 1
}

# ────────────────────────────────────────────────────────────────────────────
# Subcommands
# ────────────────────────────────────────────────────────────────────────────

cmd_init() {
  mkdir -p "$STATE_DIR"
  if [ -f "$STATE_FILE" ]; then
    echo "[neewe] state already exists at $STATE_FILE — leaving untouched" >&2
    return 0
  fi
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "$STATE_FILE" <<EOF
{
  "\$schema": "neewe-state-v1",
  "neewe_version": "${NEEWE_VERSION}",
  "phase": "00-intake",
  "phase_started_at": "${now}",
  "mode": "balanced",
  "model_routing": {
    "main": "opusplan",
    "subagents": "sonnet",
    "background": "haiku"
  },
  "permission_mode": "default",
  "output_style": "NEEWE Startup",
  "context_mode_enabled": false,
  "caveman_mode": "off",
  "hook_profile": "standard",
  "active_goal": null,
  "active_squad": null,
  "cost_budget": {
    "cap_usd": 5.00,
    "spent_usd": 0.00
  }
}
EOF
  echo "[neewe] initialized $STATE_FILE (phase: 00-intake, mode: balanced)"
}

cmd_show() {
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  if _have_jq; then jq . "$STATE_FILE"; else cat "$STATE_FILE"; fi
}

cmd_set_phase() {
  local phase="${1:-}"
  case "$phase" in
    00-intake|01-spec|02-plan|03-execute|04-validate|05-goal-mode) ;;
    "")
      echo "[neewe] ERROR: missing phase. Usage: neewe set-phase <phase>" >&2
      echo "        Valid phases: 00-intake | 01-spec | 02-plan | 03-execute | 04-validate | 05-goal-mode" >&2
      return 1
      ;;
    *)
      echo "[neewe] ERROR: unknown phase '$phase'. Valid: 00-intake|01-spec|02-plan|03-execute|04-validate|05-goal-mode" >&2
      return 1
      ;;
  esac
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  acquire_lock
  json_set_phase "$STATE_FILE" "$phase"
  echo "[neewe] phase → $phase"
}

cmd_get() {
  local field="${1:-}"
  if [ -z "$field" ]; then
    echo "[neewe] ERROR: missing field. Usage: neewe get <dot.path>" >&2
    return 1
  fi
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  json_get "$STATE_FILE" "$field"
}

cmd_goal() {
  # neewe goal "<description>" [--budget <usd>]
  local description="${1:-}"
  shift || true
  local budget=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --budget) budget="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -z "$description" ]; then
    echo "[neewe] ERROR: missing goal description. Usage: neewe goal \"<text>\" [--budget <usd>]" >&2
    return 1
  fi
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  acquire_lock
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  if _have_jq; then
    if [ -n "$budget" ]; then
      jq --arg g "$description" --arg t "$now" --argjson b "$budget" \
         '.active_goal = $g | .goal_started_at = $t | .cost_budget.cap_usd = $b | .cost_budget.spent_usd = 0' \
         "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
    else
      jq --arg g "$description" --arg t "$now" \
         '.active_goal = $g | .goal_started_at = $t | .cost_budget.spent_usd = 0' \
         "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
    fi
  elif _have_python; then
    _py - "$STATE_FILE" "$description" "$now" "$budget" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f: d = json.load(f)
d['active_goal'] = sys.argv[2]
d['goal_started_at'] = sys.argv[3]
if len(sys.argv) > 4 and sys.argv[4]:
    d.setdefault('cost_budget', {})['cap_usd'] = float(sys.argv[4])
d.setdefault('cost_budget', {})['spent_usd'] = 0.0
with open(sys.argv[1] + '.tmp', 'w') as f: json.dump(d, f, indent=2)
PYEOF
    mv "${STATE_FILE}.tmp" "$STATE_FILE"
  else
    echo "ERROR: need jq or python" >&2; return 1
  fi
  local cap
  cap=$(json_get "$STATE_FILE" "cost_budget.cap_usd")
  echo "[neewe] goal → \"$description\" (budget cap: \$$cap)"
}

cmd_mode() {
  # neewe mode <thrift|balanced|quality>
  local mode="${1:-}"
  case "$mode" in
    thrift|balanced|quality) ;;
    "")
      echo "[neewe] ERROR: missing mode. Usage: neewe mode <thrift|balanced|quality>" >&2
      return 1
      ;;
    *)
      echo "[neewe] ERROR: invalid mode '$mode'. Valid: thrift | balanced | quality" >&2
      return 1
      ;;
  esac
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  # Cascade mode → model_routing / caveman / hook_profile / output_style / effort
  local main_model subagent_model bg_model caveman_mode hook_profile output_style effort
  case "$mode" in
    thrift)
      main_model="sonnet"; subagent_model="sonnet"; bg_model="haiku"
      caveman_mode="full"; hook_profile="minimal"; output_style="NEEWE Startup"; effort="low"
      ;;
    balanced)
      main_model="opusplan"; subagent_model="sonnet"; bg_model="haiku"
      caveman_mode="full"; hook_profile="standard"; output_style="NEEWE Startup"; effort="high"
      ;;
    quality)
      main_model="opus[1m]"; subagent_model="opus"; bg_model="haiku"
      caveman_mode="off"; hook_profile="strict"; output_style="Explanatory"; effort="xhigh"
      ;;
  esac
  acquire_lock
  if _have_jq; then
    jq --arg m "$mode" --arg main "$main_model" --arg sub "$subagent_model" --arg bg "$bg_model" \
       --arg cm "$caveman_mode" --arg hp "$hook_profile" --arg os "$output_style" --arg ef "$effort" \
       '.mode = $m
        | .model_routing.main = $main
        | .model_routing.subagents = $sub
        | .model_routing.background = $bg
        | .caveman_mode = $cm
        | .hook_profile = $hp
        | .output_style = $os
        | .effort = $ef' \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  elif _have_python; then
    _py - "$STATE_FILE" "$mode" "$main_model" "$subagent_model" "$bg_model" "$caveman_mode" "$hook_profile" "$output_style" "$effort" <<'PYEOF'
import json, sys
f, mode, main, sub, bg, cm, hp, os_style, ef = sys.argv[1], *sys.argv[2:10]
with open(f) as fh: d = json.load(fh)
d['mode'] = mode
d.setdefault('model_routing', {}).update({'main': main, 'subagents': sub, 'background': bg})
d['caveman_mode'] = cm
d['hook_profile'] = hp
d['output_style'] = os_style
d['effort'] = ef
with open(f + '.tmp', 'w') as fh: json.dump(d, fh, indent=2)
PYEOF
    mv "${STATE_FILE}.tmp" "$STATE_FILE"
  else
    echo "ERROR: need jq or python" >&2; return 1
  fi
  echo "[neewe] mode → $mode  (main=$main_model, sub=$subagent_model, bg=$bg_model, caveman=$caveman_mode, hooks=$hook_profile, effort=$effort)"
}

cmd_add_cost() {
  # neewe add-cost <usd_amount> [--tool <name>] [--model <name>]
  # Internal helper used by cost-tracker hook. Appends entry to .neewe/.cost-log
  # and atomically increments cost_budget.spent_usd in state.json.
  local amount="${1:-}"
  shift || true
  local tool="" model=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --tool) tool="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -z "$amount" ]; then return 0; fi
  if [ ! -f "$STATE_FILE" ]; then return 0; fi   # silent no-op if state not initialized
  local now log
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  log="${STATE_DIR}/.cost-log"
  printf '{"ts":"%s","amount_usd":%s,"tool":"%s","model":"%s"}\n' "$now" "$amount" "$tool" "$model" >> "$log"
  acquire_lock
  if _have_jq; then
    jq --argjson a "$amount" '.cost_budget.spent_usd = (.cost_budget.spent_usd // 0) + $a' \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  elif _have_python; then
    _py - "$STATE_FILE" "$amount" <<'PYEOF'
import json, sys
f, a = sys.argv[1], float(sys.argv[2])
with open(f) as fh: d = json.load(fh)
d.setdefault('cost_budget', {})['spent_usd'] = float(d.get('cost_budget', {}).get('spent_usd', 0)) + a
with open(f + '.tmp', 'w') as fh: json.dump(d, fh, indent=2)
PYEOF
    mv "${STATE_FILE}.tmp" "$STATE_FILE"
  fi
}

cmd_cost_report() {
  # neewe cost-report [--since <ISO-date>]
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file." >&2; return 1
  fi
  local log="${STATE_DIR}/.cost-log"
  if [ ! -f "$log" ]; then
    echo "[neewe] no cost log yet at $log"
    return 0
  fi
  local cap spent
  cap=$(json_get "$STATE_FILE" "cost_budget.cap_usd")
  spent=$(json_get "$STATE_FILE" "cost_budget.spent_usd")
  local total_entries
  total_entries=$(wc -l < "$log" 2>/dev/null || echo 0)
  echo "Cost Budget"
  echo "  Cap:    \$$cap"
  echo "  Spent:  \$$spent"
  echo ""
  if [ -n "$cap" ] && [ -n "$spent" ] && _have_python; then
    local pct
    pct=$(_py -c "print(f'{(float(\"$spent\")/float(\"$cap\"))*100:.1f}%' if float('$cap')>0 else '0.0%')")
    echo "  Utilization: $pct"
    echo ""
  fi
  echo "Recent entries (last 10):"
  tail -10 "$log" 2>/dev/null
  echo ""
  echo "Total log entries: $total_entries"
}

cmd_help() {
  cat <<'EOF'
neewe — NEEWE Framework CLI

USAGE:
  neewe <command> [args]

COMMANDS:
  init                    Create .neewe/state.json with defaults
  show                    Pretty-print current state
  set-phase <phase>       Atomically update phase + phase_started_at
                          phases: 00-intake | 01-spec | 02-plan | 03-execute
                                  | 04-validate | 05-goal-mode
  get <field>             Read a field (dot-path, e.g. model_routing.main)
  goal "<text>" [--budget USD]
                          Set active goal + reset spent + (optionally) set budget cap
  mode <m>                Cascade mode → model_routing / caveman / hook_profile / output_style / effort
                          modes: thrift | balanced | quality
                            thrift  = sonnet+sonnet+haiku, caveman:full, hooks:minimal, effort:low
                            balanced = opusplan+sonnet+haiku, caveman:full, hooks:standard, effort:high
                            quality = opus[1m]+opus+haiku, caveman:off, hooks:strict, effort:xhigh
  add-cost <USD> [--tool T] [--model M]
                          Internal: appends to .cost-log + increments spent_usd. Used by hooks.
  cost-report             Show budget cap, spent, utilization %, last 10 entries
  help                    Print this help

EXAMPLES:
  neewe init
  neewe goal "Ship the /search endpoint" --budget 3.00
  neewe mode balanced
  neewe set-phase 03-execute
  neewe cost-report
  neewe get cost_budget.spent_usd

State file:    .neewe/state.json
Cost log:      .neewe/.cost-log    (JSONL, append-only, hook-managed)
Lock file:     .neewe/.state.lock  (atomic mkdir-based, 5s stale threshold)
EOF
}

# ────────────────────────────────────────────────────────────────────────────
# Dispatcher
# ────────────────────────────────────────────────────────────────────────────

case "${1:-help}" in
  init)        cmd_init ;;
  show)        cmd_show ;;
  set-phase)   shift; cmd_set_phase "${1:-}" ;;
  get)         shift; cmd_get "${1:-}" ;;
  goal)        shift; cmd_goal "$@" ;;
  mode)        shift; cmd_mode "${1:-}" ;;
  add-cost)    shift; cmd_add_cost "$@" ;;
  cost-report) cmd_cost_report ;;
  help|-h|--help) cmd_help ;;
  *)
    echo "[neewe] unknown command: $1" >&2
    cmd_help
    exit 1
    ;;
esac
