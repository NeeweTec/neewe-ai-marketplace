#!/usr/bin/env bash
# neewe — NEEWE Framework CLI (Sprint 1 minimum: phase-state primitive)
#
# Subcommands:
#   neewe init                          Create .neewe/state.json with defaults
#   neewe show                          Pretty-print current state
#   neewe set-phase <phase>             Atomically update phase + phase_started_at
#   neewe get <field>                   Read a field (dot-path: model_routing.main)
#   neewe help                          Print this help
#
# Phases: 00-intake | 01-spec | 02-plan | 03-execute | 04-validate | 05-goal-mode
#
# State file: .neewe/state.json  (lockfile: .neewe/.state.lock — atomic mkdir-based)
#
# Polyglot: invoked from neewe.cmd on Windows (Git Bash); direct on Unix.

set -euo pipefail

NEEWE_VERSION="0.1.0"
STATE_DIR=".neewe"
STATE_FILE="${STATE_DIR}/state.json"
LOCK_DIR="${STATE_DIR}/.state.lock"

# ────────────────────────────────────────────────────────────────────────────
# JSON helpers (prefer jq; fall back to python3)
# ────────────────────────────────────────────────────────────────────────────

_have_jq() { command -v jq >/dev/null 2>&1; }
_have_python() { command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; }

_py() {
  if command -v python3 >/dev/null 2>&1; then python3 "$@"; else python "$@"; fi
}

json_get() {
  # json_get <file> <dot.path>
  local file="$1" path="$2"
  if _have_jq; then
    jq -r ".${path} // empty" "$file"
  elif _have_python; then
    _py -c "import json,sys; d=json.load(open('${file}'));
parts='${path}'.split('.')
for p in parts: d=d.get(p, '') if isinstance(d, dict) else ''
print(d if d is not None else '')"
  else
    echo "ERROR: need jq or python to parse JSON" >&2
    return 1
  fi
}

json_set_phase() {
  # json_set_phase <file> <new_phase>
  local file="$1" phase="$2"
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  if _have_jq; then
    jq --arg p "$phase" --arg t "$now" '.phase = $p | .phase_started_at = $t' "$file" > "${file}.tmp"
    mv "${file}.tmp" "$file"
  elif _have_python; then
    _py -c "
import json
with open('${file}') as f: d = json.load(f)
d['phase'] = '${phase}'
d['phase_started_at'] = '${now}'
with open('${file}.tmp', 'w') as f: json.dump(d, f, indent=2)
" && mv "${file}.tmp" "$file"
  else
    echo "ERROR: need jq or python to mutate JSON" >&2
    return 1
  fi
}

json_mutate() {
  # json_mutate <file> <jq-expression>
  # Apply an arbitrary jq mutation (or python equivalent) to the file atomically.
  local file="$1" jq_expr="$2" py_code="$3"
  if _have_jq; then
    jq "$jq_expr" "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
  elif _have_python; then
    _py -c "$py_code" && mv "${file}.tmp" "$file"
  else
    echo "ERROR: need jq or python to mutate JSON" >&2
    return 1
  fi
}

# ────────────────────────────────────────────────────────────────────────────
# Lock helpers (atomic mkdir-based — POSIX-portable + works on Git Bash)
# ────────────────────────────────────────────────────────────────────────────

acquire_lock() {
  # Stale threshold = 5s. JSON writes complete in <100ms; anything held longer
  # is a poison pill from a crashed prior invocation.
  # On stale detection we clear and retry mkdir immediately (no sleep).
  local max_attempts=20
  local stale_threshold_sec=5
  local attempt=0
  while [ $attempt -lt $max_attempts ]; do
    if mkdir "$LOCK_DIR" 2>/dev/null; then
      trap 'rmdir "'"$LOCK_DIR"'" 2>/dev/null || true' EXIT
      return 0
    fi
    # Lock exists. Check if it's stale (poison pill from crashed prior run).
    if [ -d "$LOCK_DIR" ]; then
      local lock_mtime age
      lock_mtime=$(stat -c %Y "$LOCK_DIR" 2>/dev/null || stat -f %m "$LOCK_DIR" 2>/dev/null || echo 0)
      age=$(( $(date +%s) - lock_mtime ))
      if [ "$age" -gt "$stale_threshold_sec" ]; then
        echo "[neewe] clearing stale lock (age=${age}s > ${stale_threshold_sec}s threshold) at $LOCK_DIR" >&2
        rmdir "$LOCK_DIR" 2>/dev/null || true
        continue   # retry mkdir immediately, no sleep
      fi
    fi
    # Lock is fresh — another invocation is mid-write. Jittered wait (50-200 ms).
    sleep "0.$(printf '%03d' $((50 + RANDOM % 150)))"
    attempt=$((attempt + 1))
  done
  echo "[neewe] ERROR: could not acquire lock after ${max_attempts} attempts (lock at $LOCK_DIR)" >&2
  return 1
}

# ────────────────────────────────────────────────────────────────────────────
# Subcommands
# ────────────────────────────────────────────────────────────────────────────

cmd_init() {
  mkdir -p "$STATE_DIR"
  if [ -f "$STATE_FILE" ]; then
    echo "[neewe] state already exists at $STATE_FILE — leaving untouched" >&2
    return 0
  fi
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "$STATE_FILE" <<EOF
{
  "\$schema": "neewe-state-v1",
  "neewe_version": "${NEEWE_VERSION}",
  "phase": "00-intake",
  "phase_started_at": "${now}",
  "mode": "balanced",
  "model_routing": {
    "main": "opusplan",
    "subagents": "sonnet",
    "background": "haiku"
  },
  "permission_mode": "default",
  "output_style": "NEEWE Startup",
  "context_mode_enabled": false,
  "caveman_mode": "off",
  "hook_profile": "standard",
  "active_goal": null,
  "active_squad": null,
  "cost_budget": {
    "cap_usd": 5.00,
    "spent_usd": 0.00
  }
}
EOF
  echo "[neewe] initialized $STATE_FILE (phase: 00-intake, mode: balanced)"
}

cmd_show() {
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  if _have_jq; then jq . "$STATE_FILE"; else cat "$STATE_FILE"; fi
}

cmd_set_phase() {
  local phase="${1:-}"
  case "$phase" in
    # Legacy phase names (Sprint 1–5 — kept for back-compat)
    00-intake|01-spec|02-plan|03-execute|04-validate|05-goal-mode) ;;
    # 7-stage user flow (v0.8+ — emitted by /neewe-stage and TUI)
    init|bootstrap|discovery|planning|dispatch|dispatching|orchestration|orchestrating|execution|verification|review|release|retro|finished) ;;
    "")
      echo "[neewe] ERROR: missing phase. Usage: neewe set-phase <phase>" >&2
      echo "        7-stage flow: init | discovery | planning | dispatch | orchestration | execution | release" >&2
      echo "        Legacy:       00-intake | 01-spec | 02-plan | 03-execute | 04-validate | 05-goal-mode" >&2
      return 1
      ;;
    *)
      echo "[neewe] ERROR: unknown phase '$phase'." >&2
      echo "        7-stage flow: init | discovery | planning | dispatch | orchestration | execution | release" >&2
      echo "        Legacy:       00-intake | 01-spec | 02-plan | 03-execute | 04-validate | 05-goal-mode" >&2
      return 1
      ;;
  esac
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  acquire_lock
  json_set_phase "$STATE_FILE" "$phase"
  echo "[neewe] phase → $phase"
}

cmd_get() {
  local field="${1:-}"
  if [ -z "$field" ]; then
    echo "[neewe] ERROR: missing field. Usage: neewe get <dot.path>" >&2
    return 1
  fi
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  json_get "$STATE_FILE" "$field"
}

cmd_goal() {
  # neewe goal "<description>" [--budget <usd>]
  local description="${1:-}"
  shift || true
  local budget=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --budget) budget="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -z "$description" ]; then
    echo "[neewe] ERROR: missing goal description. Usage: neewe goal \"<text>\" [--budget <usd>]" >&2
    return 1
  fi
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  acquire_lock
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  if _have_jq; then
    if [ -n "$budget" ]; then
      jq --arg g "$description" --arg t "$now" --argjson b "$budget" \
         '.active_goal = $g | .goal_started_at = $t | .cost_budget.cap_usd = $b | .cost_budget.spent_usd = 0' \
         "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
    else
      jq --arg g "$description" --arg t "$now" \
         '.active_goal = $g | .goal_started_at = $t | .cost_budget.spent_usd = 0' \
         "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
    fi
  elif _have_python; then
    _py - "$STATE_FILE" "$description" "$now" "$budget" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f: d = json.load(f)
d['active_goal'] = sys.argv[2]
d['goal_started_at'] = sys.argv[3]
if len(sys.argv) > 4 and sys.argv[4]:
    d.setdefault('cost_budget', {})['cap_usd'] = float(sys.argv[4])
d.setdefault('cost_budget', {})['spent_usd'] = 0.0
with open(sys.argv[1] + '.tmp', 'w') as f: json.dump(d, f, indent=2)
PYEOF
    mv "${STATE_FILE}.tmp" "$STATE_FILE"
  else
    echo "ERROR: need jq or python" >&2; return 1
  fi
  local cap
  cap=$(json_get "$STATE_FILE" "cost_budget.cap_usd")
  echo "[neewe] goal → \"$description\" (budget cap: \$$cap)"
}

cmd_mode() {
  # neewe mode <thrift|balanced|quality>
  local mode="${1:-}"
  case "$mode" in
    thrift|balanced|quality) ;;
    "")
      echo "[neewe] ERROR: missing mode. Usage: neewe mode <thrift|balanced|quality>" >&2
      return 1
      ;;
    *)
      echo "[neewe] ERROR: invalid mode '$mode'. Valid: thrift | balanced | quality" >&2
      return 1
      ;;
  esac
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file. Run: neewe init" >&2
    return 1
  fi
  # Cascade mode → model_routing / caveman / hook_profile / output_style / effort
  local main_model subagent_model bg_model caveman_mode hook_profile output_style effort
  case "$mode" in
    thrift)
      main_model="sonnet"; subagent_model="sonnet"; bg_model="haiku"
      caveman_mode="full"; hook_profile="minimal"; output_style="NEEWE Startup"; effort="low"
      ;;
    balanced)
      main_model="opusplan"; subagent_model="sonnet"; bg_model="haiku"
      caveman_mode="full"; hook_profile="standard"; output_style="NEEWE Startup"; effort="high"
      ;;
    quality)
      main_model="opus[1m]"; subagent_model="opus"; bg_model="haiku"
      caveman_mode="off"; hook_profile="strict"; output_style="Explanatory"; effort="xhigh"
      ;;
  esac
  acquire_lock
  if _have_jq; then
    jq --arg m "$mode" --arg main "$main_model" --arg sub "$subagent_model" --arg bg "$bg_model" \
       --arg cm "$caveman_mode" --arg hp "$hook_profile" --arg os "$output_style" --arg ef "$effort" \
       '.mode = $m
        | .model_routing.main = $main
        | .model_routing.subagents = $sub
        | .model_routing.background = $bg
        | .caveman_mode = $cm
        | .hook_profile = $hp
        | .output_style = $os
        | .effort = $ef' \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  elif _have_python; then
    _py - "$STATE_FILE" "$mode" "$main_model" "$subagent_model" "$bg_model" "$caveman_mode" "$hook_profile" "$output_style" "$effort" <<'PYEOF'
import json, sys
f, mode, main, sub, bg, cm, hp, os_style, ef = sys.argv[1], *sys.argv[2:10]
with open(f) as fh: d = json.load(fh)
d['mode'] = mode
d.setdefault('model_routing', {}).update({'main': main, 'subagents': sub, 'background': bg})
d['caveman_mode'] = cm
d['hook_profile'] = hp
d['output_style'] = os_style
d['effort'] = ef
with open(f + '.tmp', 'w') as fh: json.dump(d, fh, indent=2)
PYEOF
    mv "${STATE_FILE}.tmp" "$STATE_FILE"
  else
    echo "ERROR: need jq or python" >&2; return 1
  fi
  echo "[neewe] mode → $mode  (main=$main_model, sub=$subagent_model, bg=$bg_model, caveman=$caveman_mode, hooks=$hook_profile, effort=$effort)"
}

cmd_add_cost() {
  # neewe add-cost <usd_amount> [--tool <name>] [--model <name>]
  # Internal helper used by cost-tracker hook. Appends entry to .neewe/.cost-log
  # and atomically increments cost_budget.spent_usd in state.json.
  local amount="${1:-}"
  shift || true
  local tool="" model=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --tool) tool="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -z "$amount" ]; then return 0; fi
  if [ ! -f "$STATE_FILE" ]; then return 0; fi   # silent no-op if state not initialized
  local now log
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  log="${STATE_DIR}/.cost-log"
  printf '{"ts":"%s","amount_usd":%s,"tool":"%s","model":"%s"}\n' "$now" "$amount" "$tool" "$model" >> "$log"
  acquire_lock
  if _have_jq; then
    jq --argjson a "$amount" '.cost_budget.spent_usd = (.cost_budget.spent_usd // 0) + $a' \
       "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  elif _have_python; then
    _py - "$STATE_FILE" "$amount" <<'PYEOF'
import json, sys
f, a = sys.argv[1], float(sys.argv[2])
with open(f) as fh: d = json.load(fh)
d.setdefault('cost_budget', {})['spent_usd'] = float(d.get('cost_budget', {}).get('spent_usd', 0)) + a
with open(f + '.tmp', 'w') as fh: json.dump(d, fh, indent=2)
PYEOF
    mv "${STATE_FILE}.tmp" "$STATE_FILE"
  fi
}

cmd_cost_report() {
  # neewe cost-report [--since <ISO-date>]
  if [ ! -f "$STATE_FILE" ]; then
    echo "[neewe] no state file." >&2; return 1
  fi
  local log="${STATE_DIR}/.cost-log"
  if [ ! -f "$log" ]; then
    echo "[neewe] no cost log yet at $log"
    return 0
  fi
  local cap spent
  cap=$(json_get "$STATE_FILE" "cost_budget.cap_usd")
  spent=$(json_get "$STATE_FILE" "cost_budget.spent_usd")
  local total_entries
  total_entries=$(wc -l < "$log" 2>/dev/null || echo 0)
  echo "Cost Budget"
  echo "  Cap:    \$$cap"
  echo "  Spent:  \$$spent"
  echo ""
  if [ -n "$cap" ] && [ -n "$spent" ] && _have_python; then
    local pct
    pct=$(_py -c "print(f'{(float(\"$spent\")/float(\"$cap\"))*100:.1f}%' if float('$cap')>0 else '0.0%')")
    echo "  Utilization: $pct"
    echo ""
  fi
  echo "Recent entries (last 10):"
  tail -10 "$log" 2>/dev/null
  echo ""
  echo "Total log entries: $total_entries"
}

cmd_l4_init() {
  # Bootstrap MNEME L4 memory tiers. Idempotent.
  local created=0 skipped=0 new_log=""
  # Ensure state.json first.
  if [ ! -f "$STATE_FILE" ]; then
    cmd_init
    new_log="state.json initialized"
  fi
  # Vault + graph + raw + planning + handoffs + gates + debug dirs.
  local dirs=(
    ".neewe/vault/concepts" ".neewe/vault/entities" ".neewe/vault/decisions"
    ".neewe/vault/specs" ".neewe/vault/gates" ".neewe/vault/sources" ".neewe/vault/lint"
    ".neewe/graph" ".neewe/raw/papers" ".neewe/raw/threads" ".neewe/raw/clips" ".neewe/raw/assets"
    ".neewe/planning" ".neewe/handoffs" ".neewe/gates" ".neewe/debug"
  )
  for d in "${dirs[@]}"; do
    if [ ! -d "$d" ]; then mkdir -p "$d" && created=$((created + 1)); else skipped=$((skipped + 1)); fi
  done
  # Seed vault/index.md.
  if [ ! -f ".neewe/vault/index.md" ]; then
    cat > ".neewe/vault/index.md" <<'IDX'
# Vault Index

Content-oriented catalog. Add entries below as you create vault pages.

## Concepts
(empty)

## Entities
(services, modules, classes — link with [[wikilinks]])

## Decisions (ADRs)
(architectural decisions — one file per decision in decisions/)

## Specs
(00-OV / 01-FN / 02-PL mirrored from spec authoring)

## Gates
(governance trio verdicts per phase)

## Sources
(papers, threads, PRs, screenshots — summaries with provenance)
IDX
    created=$((created + 1))
  fi
  # Seed vault/log.md and append init entry.
  local now_date
  now_date=$(date -u +"%Y-%m-%d")
  if [ ! -f ".neewe/vault/log.md" ]; then
    cat > ".neewe/vault/log.md" <<LOG
# Vault Log

Append-only chronological journal. Format: \`## [YYYY-MM-DD] verb | subject\`.
Parseable via: \`grep "^## \[" log.md\`.

---

## [$now_date] init | NEEWE L4 bootstrapped
LOG
    created=$((created + 1))
  else
    printf '\n## [%s] init-run | re-initialized (%d dirs created, %d skipped)\n' "$now_date" "$created" "$skipped" >> ".neewe/vault/log.md"
  fi
  # Seed vault/schema.md.
  if [ ! -f ".neewe/vault/schema.md" ]; then
    cat > ".neewe/vault/schema.md" <<'SCH'
# Vault Schema (NEEWE-MNEME-v1)

## Conventions
- File naming: kebab-case, lowercase, .md
- Links: `[[Page Name]]` (Obsidian-compatible bidirectional)
- Frontmatter (YAML, required):
  - `tags:` array
  - `created:` ISO-8601
  - `last_updated:` ISO-8601
  - `confidence:` EXTRACTED | INFERRED | AMBIGUOUS
  - `sources:` array of [[source/<id>]]
- Body: elevator pitch, H2 sections, ending [[See also]] block

## Lifecycle (Karpathy LLM-Wiki pattern)
1. Ingest — new raw source → page + entity/concept updates + log entry
2. Query — user question → relevant pages → answer FILED BACK as new page
3. Lint — periodic — contradictions, stale claims, orphans, gaps
4. Schema-Evolve — when conventions need updating, edit THIS file

## See also
- [[index]] — content catalog
- [[log]] — chronological journal
SCH
    created=$((created + 1))
  fi
  # Seed debug/knowledge-base.md.
  if [ ! -f ".neewe/debug/knowledge-base.md" ]; then
    cat > ".neewe/debug/knowledge-base.md" <<'DKB'
# Debug Knowledge Base

Append-only catalog of bugs encountered + root causes + fixes. Future-self looks here BEFORE re-investigating recurring symptoms.

Format per entry:

## YYYY-MM-DD — <one-line symptom>

- **Symptom:** <observable behavior>
- **Root cause:** <what was actually wrong>
- **Fix:** <commit SHA + summary>
- **Regression test:** <test file:line>
- **Recurrence guard:** <what would catch this earlier next time>
DKB
    created=$((created + 1))
  fi
  # CLAUDE.md template seed — only if missing.
  if [ ! -f "CLAUDE.md" ]; then
    local template_path="${CLAUDE_PLUGIN_ROOT:-}/templates/CLAUDE.md.template"
    if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$template_path" ]; then
      cp "$template_path" "CLAUDE.md"
      created=$((created + 1))
    else
      cat > "CLAUDE.md" <<'CMD'
# CLAUDE.md — NEEWE-managed project

This project uses the NEEWE Framework. Doctrine: see using-neewe skill (auto-injected via SessionStart).

## L4 Memory Consultation Rule
Before grepping code, consult MNEME:
1. T1 Hot — CLAUDE.md hierarchy (this file)
2. T2 Vault — .neewe/vault/ (concept pages, ADRs, source summaries)
3. T3 Graph — .neewe/graph/ via Graphify MCP (when installed)
4. Raw code — last resort

After answering: fold the answer back into the vault.

(Run `neewe l4-init` to bootstrap; edit this file as your project doctrine grows.)
CMD
      created=$((created + 1))
    fi
  fi
  # .gitignore additions (idempotent).
  local gi=".gitignore"
  local entries=(
    ".neewe/state.json" ".neewe/.cost-log" ".neewe/.state.lock"
    ".neewe/handoffs/" ".neewe/gates/" ".neewe/dashboard-token" ".neewe/dashboard.json"
    ".neewe/vault/.obsidian/"
  )
  if [ -f "$gi" ]; then
    for e in "${entries[@]}"; do
      if ! grep -qxF "$e" "$gi" 2>/dev/null; then
        echo "$e" >> "$gi"
      fi
    done
  fi
  # Report.
  echo "[neewe] l4-init complete. created=$created skipped=$skipped"
  echo "[neewe] vault: .neewe/vault/  graph: .neewe/graph/  raw: .neewe/raw/"
  echo "[neewe] next: edit CLAUDE.md to add project-specific doctrine; install graphify (pip install graphifyy) for T3 graph"
}

cmd_inline() {
  # Markdown-rich status view designed to be rendered by Claude Code chat.
  # Shows stage stepper + cost meter + active goal + last gates + last events.
  if [ ! -f "$STATE_FILE" ]; then
    cat <<EOF
## NEEWE — not initialized

No \`.neewe/state.json\` found in \`$(pwd)\`.

**Next:** run \`/neewe-start\` (or in shell: \`neewe init\`) to bootstrap this project.
EOF
    return 0
  fi

  local PHASE MODE GOAL SQUAD PERM STYLE LOCALE CAP SPENT
  PHASE=$(json_get "$STATE_FILE" "phase"); PHASE=${PHASE:-unknown}
  MODE=$(json_get "$STATE_FILE" "mode"); MODE=${MODE:-balanced}
  GOAL=$(json_get "$STATE_FILE" "active_goal"); GOAL=${GOAL:-(none)}
  SQUAD=$(json_get "$STATE_FILE" "active_squad"); SQUAD=${SQUAD:-(none)}
  PERM=$(json_get "$STATE_FILE" "permission_mode"); PERM=${PERM:-default}
  STYLE=$(json_get "$STATE_FILE" "output_style"); STYLE=${STYLE:-NEEWE Startup}
  LOCALE=$(json_get "$STATE_FILE" "locale.user_language"); LOCALE=${LOCALE:-en-US}
  CAP=$(json_get "$STATE_FILE" "cost_budget.cap_usd"); CAP=${CAP:-0}
  SPENT=$(json_get "$STATE_FILE" "cost_budget.spent_usd"); SPENT=${SPENT:-0}

  # Map phase → 7-step stage index
  local STAGE_IDX
  case "$PHASE" in
    init|bootstrap)          STAGE_IDX=0 ;;
    discovery)               STAGE_IDX=1 ;;
    planning)                STAGE_IDX=2 ;;
    dispatch|dispatching)    STAGE_IDX=3 ;;
    orchestration|orchestrating) STAGE_IDX=4 ;;
    execution)               STAGE_IDX=5 ;;
    verification|review|release|retro|finished) STAGE_IDX=6 ;;
    *)                       STAGE_IDX=0 ;;
  esac

  # Build stepper line
  local STAGES=("Initial" "Ground" "Plan" "Dispatch" "Orchestrate" "Code" "Finish")
  local STEPPER=""
  for i in 0 1 2 3 4 5 6; do
    if [ "$i" -lt "$STAGE_IDX" ]; then
      STEPPER+="◉ ${STAGES[$i]}"
    elif [ "$i" -eq "$STAGE_IDX" ]; then
      STEPPER+="**● ${STAGES[$i]}**"
    else
      STEPPER+="○ ${STAGES[$i]}"
    fi
    [ "$i" -lt 6 ] && STEPPER+=" → "
  done

  # Cost percent
  local PCT
  PCT=$(awk -v s="$SPENT" -v c="$CAP" 'BEGIN { if (c <= 0) print "0.0"; else printf "%.1f", (s / c) * 100 }')

  # Cost bar (12 chars)
  local FILLED EMPTY BAR
  FILLED=$(awk -v p="$PCT" 'BEGIN { f = int(p * 12 / 100); if (f > 12) f = 12; print f }')
  EMPTY=$((12 - FILLED))
  BAR=""
  for ((i=0; i<FILLED; i++)); do BAR+="█"; done
  for ((i=0; i<EMPTY; i++)); do BAR+="░"; done

  # Latest gate (if any)
  local GATE_LINE=""
  if [ -d ".neewe/gates" ]; then
    local LATEST_PHASE LATEST_AGG QA TL PO
    LATEST_PHASE=$(ls -1 .neewe/gates 2>/dev/null | head -1)
    if [ -n "$LATEST_PHASE" ] && [ -f ".neewe/gates/$LATEST_PHASE/latest/aggregate.json" ]; then
      LATEST_AGG=".neewe/gates/$LATEST_PHASE/latest/aggregate.json"
      QA=$(json_get "$LATEST_AGG" "verdicts.qa")
      TL=$(json_get "$LATEST_AGG" "verdicts.tech_lead")
      PO=$(json_get "$LATEST_AGG" "verdicts.po")
      GATE_LINE="| **Last gate** ($LATEST_PHASE) | QA: \`${QA:-—}\` · TL: \`${TL:-—}\` · PO: \`${PO:-—}\` |"
    fi
  fi

  # Recent events (last 5)
  local EVENTS=""
  if [ -f ".neewe/vault/log.md" ]; then
    EVENTS=$(grep -E '^## \[' .neewe/vault/log.md 2>/dev/null | tail -5 | sed 's/^## /- /')
  fi

  cat <<EOF
## NEEWE — Current Stage

$STEPPER

| Field | Value |
|---|---|
| **Stage (internal phase)** | \`$PHASE\` |
| **Mode** | \`$MODE\` |
| **Active goal** | $GOAL |
| **Active squad** | $SQUAD |
| **Permission** | \`$PERM\` · style: \`$STYLE\` |
| **Language** | \`$LOCALE\` |
$GATE_LINE

### Cost

\`\`\`
$BAR  ${PCT}%   \$$(printf '%.2f' "$SPENT") / \$$(printf '%.2f' "$CAP")
\`\`\`

EOF

  if [ -n "$EVENTS" ]; then
    cat <<EOF
### Recent events

$EVENTS

EOF
  fi

  cat <<EOF
### Next actions

- \`/neewe-stage <name>\` to advance (names: \`ground\`, \`plan\`, \`dispatch\`, \`orchestrate\`, \`code\`, \`finish\`)
- \`/neewe-dashboard\` to open the live web dashboard
- \`/neewe-help\` for the full command reference

> The interactive TUI (\`neewe-tui\`) runs only in a **separate terminal** — Claude Code chat uses these slash commands + dashboard instead.
EOF
}

cmd_help() {
  cat <<'EOF'
neewe — NEEWE Framework CLI

USAGE:
  neewe <command> [args]

COMMANDS:
  init                    Create .neewe/state.json with defaults
  show                    Pretty-print current state
  set-phase <phase>       Atomically update phase + phase_started_at
                          7-stage flow: init | discovery | planning | dispatch
                                        | orchestration | execution | release
                          legacy:       00-intake | 01-spec | 02-plan | 03-execute
                                        | 04-validate | 05-goal-mode
  get <field>             Read a field (dot-path, e.g. model_routing.main)
  goal "<text>" [--budget USD]
                          Set active goal + reset spent + (optionally) set budget cap
  mode <m>                Cascade mode → model_routing / caveman / hook_profile / output_style / effort
                          modes: thrift | balanced | quality
                            thrift  = sonnet+sonnet+haiku, caveman:full, hooks:minimal, effort:low
                            balanced = opusplan+sonnet+haiku, caveman:full, hooks:standard, effort:high
                            quality = opus[1m]+opus+haiku, caveman:off, hooks:strict, effort:xhigh
  add-cost <USD> [--tool T] [--model M]
                          Internal: appends to .cost-log + increments spent_usd. Used by hooks.
  cost-report             Show budget cap, spent, utilization %, last 10 entries
  l4-init                 Bootstrap MNEME L4 memory tiers (vault + graph + raw + handoffs + planning).
                          Idempotent. Seeds vault/index.md + log.md + schema.md + CLAUDE.md.
  help                    Print this help

EXAMPLES:
  neewe init
  neewe goal "Ship the /search endpoint" --budget 3.00
  neewe mode balanced
  neewe set-phase execution
  neewe cost-report
  neewe get cost_budget.spent_usd

State file:    .neewe/state.json
Cost log:      .neewe/.cost-log    (JSONL, append-only, hook-managed)
Lock file:     .neewe/.state.lock  (atomic mkdir-based, 5s stale threshold)
EOF
}

cmd_start() {
  # neewe start — one-shot bootstrap: init + l4-init + inline status view.
  # Single entrypoint so the /neewe-start command body is one operation
  # (no shell && / | that the permission checker would flag).
  cmd_init
  cmd_l4_init >/dev/null 2>&1 || true
  echo ""
  cmd_inline
}

cmd_stage() {
  # neewe stage <name> — map a 7-step user stage to its internal phase,
  # transition, then show the inline view. One operation for /neewe-stage.
  local name="${1:-}"
  local phase=""
  case "$name" in
    ground)       phase="discovery" ;;
    plan)         phase="planning" ;;
    dispatch)     phase="dispatch" ;;
    orchestrate)  phase="orchestration" ;;
    code)         phase="execution" ;;
    finish)       phase="release" ;;
    "")
      echo "[neewe] ERROR: missing stage. Usage: neewe stage <ground|plan|dispatch|orchestrate|code|finish>" >&2
      return 1
      ;;
    *)
      echo "[neewe] ERROR: unknown stage '$name'. Try: ground | plan | dispatch | orchestrate | code | finish" >&2
      return 1
      ;;
  esac
  cmd_set_phase "$phase"
  echo ""
  cmd_inline
}

# ────────────────────────────────────────────────────────────────────────────
# Dispatcher
# ────────────────────────────────────────────────────────────────────────────

# No-arg invocation has two modes:
#   1. Inside Claude Code chat (or any non-TTY harness): print the inline
#      markdown stage view — that's what the chat surface can actually render.
#   2. Standalone terminal (TTY) without CLAUDECODE/CLAUDE_PLUGIN_ROOT: open
#      the interactive Ink TUI.
# Subcommands always work for automation.
if [ $# -eq 0 ]; then
  # Detection: if we're under Claude Code, OR stdout is not a TTY, render inline.
  if [ -n "${CLAUDECODE:-}" ] || [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] || [ ! -t 1 ]; then
    cmd_inline
    exit 0
  fi
  TUI_BIN="$(dirname "${BASH_SOURCE[0]}")/neewe-tui"
  if [ -x "$TUI_BIN" ] || [ -f "$TUI_BIN" ]; then
    exec bash "$TUI_BIN"
  fi
  cmd_inline
  exit 0
fi

case "$1" in
  init)        cmd_init ;;
  start)       cmd_start ;;
  stage)       shift; cmd_stage "${1:-}" ;;
  show)        cmd_show ;;
  inline)      cmd_inline ;;
  set-phase)   shift; cmd_set_phase "${1:-}" ;;
  get)         shift; cmd_get "${1:-}" ;;
  goal)        shift; cmd_goal "$@" ;;
  mode)        shift; cmd_mode "${1:-}" ;;
  add-cost)    shift; cmd_add_cost "$@" ;;
  cost-report) cmd_cost_report ;;
  l4-init)     cmd_l4_init ;;
  tui)         exec bash "$(dirname "${BASH_SOURCE[0]}")/neewe-tui" ;;
  help|-h|--help) cmd_help ;;
  *)
    echo "[neewe] unknown command: $1" >&2
    cmd_help
    exit 1
    ;;
esac
